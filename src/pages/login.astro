---
import "../styles/global.css";
import Layout from '../layouts/Layout.astro';
import LoginForm from '../components/Login.vue';
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
---

<Layout title="Login">
	<div id="container" class="min-h-screen relative overflow-hidden font-sans">
		<img id="background" src={background.src} alt="" fetchpriority="high" class="absolute top-0 left-0 w-full h-full -z-10 object-cover opacity-60 pointer-events-none" style="filter: blur(100px);" />
		
		<main class="w-full min-h-screen flex flex-col items-center justify-center p-6 sm:p-12">
			<header class="mb-12 flex flex-col items-center text-center">
				<h1 class="text-4xl md:text-5xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-gray-900 via-gray-700 to-gray-900 tracking-tight">
					Login
				</h1>
				<p class="mt-4 text-gray-600 max-w-lg mx-auto text-lg">
					You need to securely log in before using bookmark sync, image converter, code sharer.
				</p>
			</header>
			
			<LoginForm client:only="vue" />
		</main>
	</div>
</Layout>
