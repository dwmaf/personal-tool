---
import "../../styles/global.css";
import Layout from '../../layouts/Layout.astro';
import BookmarkList from '../../components/BookmarkList.vue';
import AuthStatus from '../../components/AuthStatus.vue';
import background from '../../assets/background.svg';
---

<Layout title="Bookmark Sync">
	<div id="container" class="min-h-screen relative overflow-hidden font-sans">
		<AuthStatus client:only="vue" />
		<img id="background" src={background.src} alt="" fetchpriority="high" class="absolute top-0 left-0 w-full h-full -z-10 object-cover opacity-60 pointer-events-none" style="filter: blur(100px);" />
		
		<main class="w-full min-h-screen flex flex-col items-center justify-center p-6 sm:p-12">
			<header class="mb-12 flex flex-col items-center text-center">
				<h1 class="text-4xl md:text-5xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-gray-900 via-gray-700 to-gray-900 tracking-tight">
					Bookmark Sync
				</h1>
				<div class="mt-6 flex gap-4">
					<a href="/" class="px-5 py-2.5 bg-white border border-gray-200 text-gray-700 font-medium rounded-xl hover:bg-gray-50 transition-colors shadow-sm">
						&larr; Home
					</a>
					<a href="/bookmarks/upload" class="px-5 py-2.5 bg-gray-900 text-white font-medium rounded-xl hover:bg-gray-800 transition-colors shadow-sm">
						Upload New
					</a>
				</div>
			</header>
			
			<BookmarkList client:only="vue" />
		</main>
	</div>
</Layout>
