---
import favicon from '../assets/ai-star-icon-v2.png';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const siteTitle = title ? `${title} | Personal Toolkits` : 'Personal Toolkits';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={favicon.src} />
		<meta name="generator" content={Astro.generator} />
		<title>{siteTitle}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
